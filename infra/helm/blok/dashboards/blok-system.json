		{
			"title": "Process Heap Memory",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "bytes",
					"custom": {
						"drawStyle": "line",
						"lineInterpolation": "smooth",
						"fillOpacity": 20
					}
				}
			},
			"targets": [
				{
					"expr": "blok_process_memory_heap_bytes",
					"legendFormat": "{{trigger_type}} heap"
				}
			]
		},
		{
			"title": "Process RSS Memory",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "bytes",
					"custom": {
						"drawStyle": "line",
						"lineInterpolation": "smooth",
						"fillOpacity": 20
					}
				}
			},
			"targets": [
				{
					"expr": "blok_process_memory_rss_bytes",
					"legendFormat": "{{trigger_type}} RSS"
