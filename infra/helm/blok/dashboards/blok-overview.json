{
	"annotations": {
		"list": []
	},
	"editable": true,
	"fiscalYearStartMonth": 0,
	"graphTooltip": 1,
	"id": null,
	"links": [],
	"panels": [
		{
			"title": "Workflow Execution Rate",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "reqps",
					"custom": {
						"drawStyle": "line",
						"lineInterpolation": "smooth",
						"fillOpacity": 15
					}
				}
			},
			"targets": [
				{
					"expr": "sum(rate(blok_workflow_executions_total{env=~\"$env\"}[$__rate_interval])) by (workflow_name)",
					"legendFormat": "{{workflow_name}}"
				}
			]
		},
		{
			"title": "Workflow Error Rate",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "reqps",
					"custom": {
						"drawStyle": "line",
						"lineInterpolation": "smooth",
						"fillOpacity": 15
					},
					"color": { "mode": "palette-classic" }
				}
			},
			"targets": [
				{
					"expr": "sum(rate(blok_workflow_errors_total{env=~\"$env\"}[$__rate_interval])) by (error_category)",
					"legendFormat": "{{error_category}}"
				}
			]
		},
		{
			"title": "Success Rate",
			"type": "stat",
			"gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "percentunit",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "red", "value": null },
							{ "color": "orange", "value": 0.9 },
							{ "color": "green", "value": 0.99 }
						]
					}
				}
			},
			"targets": [
				{
					"expr": "avg(blok_trigger_success_rate{trigger_type=~\"$trigger_type\"})",
					"legendFormat": "Success Rate"
				}
			]
		},
		{
			"title": "Active Connections",
			"type": "stat",
			"gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 500 },
							{ "color": "red", "value": 1000 }
						]
					}
				}
			},
			"targets": [
				{
					"expr": "sum(blok_trigger_active_connections)",
					"legendFormat": "Connections"
				}
			]
		},
		{
			"title": "Total Throughput (RPS)",
			"type": "stat",
			"gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "reqps",
					"thresholds": {
						"mode": "absolute",
						"steps": [{ "color": "blue", "value": null }]
					}
				}
			},
			"targets": [
				{
					"expr": "sum(blok_trigger_throughput_rps)",
					"legendFormat": "RPS"
				}
			]
		},
		{
			"title": "Latency P50",
			"type": "stat",
			"gridPos": { "h": 4, "w": 4, "x": 12, "y": 8 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 0.5 },
							{ "color": "red", "value": 2 }
						]
					}
				}
			},
			"targets": [
				{
					"expr": "avg(blok_trigger_latency_p50_seconds{trigger_type=~\"$trigger_type\"})",
					"legendFormat": "P50"
				}
			]
		},
		{
			"title": "Latency P95",
			"type": "stat",
			"gridPos": { "h": 4, "w": 4, "x": 16, "y": 8 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 1 },
							{ "color": "red", "value": 5 }
						]
					}
				}
			},
			"targets": [
				{
					"expr": "avg(blok_trigger_latency_p95_seconds{trigger_type=~\"$trigger_type\"})",
					"legendFormat": "P95"
				}
			]
		},
		{
			"title": "Latency P99",
			"type": "stat",
			"gridPos": { "h": 4, "w": 4, "x": 20, "y": 8 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 2 },
							{ "color": "red", "value": 10 }
						]
					}
				}
			},
			"targets": [
				{
					"expr": "avg(blok_trigger_latency_p99_seconds{trigger_type=~\"$trigger_type\"})",
					"legendFormat": "P99"
				}
			]
		},
		{
			"title": "Workflow Duration Distribution (Histogram)",
			"type": "heatmap",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"targets": [
				{
					"expr": "sum(increase(blok_workflow_duration_seconds_bucket{env=~\"$env\"}[$__rate_interval])) by (le)",
					"format": "heatmap",
					"legendFormat": "{{le}}"
				}
			]
		},
		{
			"title": "Throughput by Trigger Type",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "reqps",
					"custom": {
						"drawStyle": "line",
						"lineInterpolation": "smooth",
						"fillOpacity": 10
					}
				}
			},
			"targets": [
				{
					"expr": "blok_trigger_throughput_rps{trigger_type=~\"$trigger_type\"}",
					"legendFormat": "{{trigger_type}} / {{trigger_name}}"
				}
			]
		},
		{
			"title": "Workflow Duration P95",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"custom": {
						"drawStyle": "line",
						"lineInterpolation": "smooth",
						"fillOpacity": 10
					}
				}
			},
			"targets": [
				{
					"expr": "histogram_quantile(0.50, sum(rate(blok_workflow_duration_seconds_bucket{env=~\"$env\"}[$__rate_interval])) by (le, workflow_name))",
					"legendFormat": "p50 {{workflow_name}}"
				},
				{
					"expr": "histogram_quantile(0.95, sum(rate(blok_workflow_duration_seconds_bucket{env=~\"$env\"}[$__rate_interval])) by (le, workflow_name))",
					"legendFormat": "p95 {{workflow_name}}"
				},
				{
					"expr": "histogram_quantile(0.99, sum(rate(blok_workflow_duration_seconds_bucket{env=~\"$env\"}[$__rate_interval])) by (le, workflow_name))",
					"legendFormat": "p99 {{workflow_name}}"
				}
			]
		}
	],
	"schemaVersion": 39,
	"tags": ["blok", "overview"],
	"templating": {
		"list": [
			{
				"name": "DS_PROMETHEUS",
				"type": "datasource",
				"query": "prometheus",
				"current": {
					"selected": true,
					"text": "prometheus",
					"value": "prometheus"
				}
			},
			{
				"name": "trigger_type",
				"type": "query",
				"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
				"query": "label_values(blok_workflow_executions_total, trigger_type)",
				"includeAll": true,
				"multi": true,
				"current": { "selected": true, "text": "All", "value": "$__all" }
			},
			{
				"name": "workflow_name",
				"type": "query",
				"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
				"query": "label_values(blok_workflow_executions_total, workflow_name)",
				"includeAll": true,
				"multi": true,
				"current": { "selected": true, "text": "All", "value": "$__all" }
			},
			{
				"name": "env",
				"type": "query",
				"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
				"query": "label_values(blok_workflow_executions_total, env)",
				"includeAll": true,
				"multi": false,
				"current": { "selected": true, "text": "All", "value": "$__all" }
			}
		]
	},
	"time": { "from": "now-1h", "to": "now" },
	"title": "Blok - Workflow Overview",
	"uid": "blok-overview"
}
