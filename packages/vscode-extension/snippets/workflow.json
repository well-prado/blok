{
	"HTTP Workflow": {
		"prefix": ["blok-workflow-http", "workflow-http"],
		"body": [
			"{",
			"\t\"name\": \"${1:my-workflow}\",",
			"\t\"description\": \"${2:Workflow description}\",",
			"\t\"version\": \"1.0.0\",",
			"\t\"trigger\": {",
			"\t\t\"http\": {",
			"\t\t\t\"method\": \"${3|GET,POST,PUT,DELETE,PATCH,ANY|}\",",
			"\t\t\t\"path\": \"${4:/}\",",
			"\t\t\t\"accept\": \"application/json\"",
			"\t\t}",
			"\t},",
			"\t\"steps\": [",
			"\t\t{",
			"\t\t\t\"name\": \"${5:first-step}\",",
			"\t\t\t\"node\": \"${6:@blok/api-call}\",",
			"\t\t\t\"type\": \"${7|module,local|}\"",
			"\t\t}",
			"\t],",
			"\t\"nodes\": {",
			"\t\t\"${5:first-step}\": {",
			"\t\t\t\"inputs\": {",
			"\t\t\t\t${8}",
			"\t\t\t}",
			"\t\t}",
			"\t}",
			"}"
		],
		"description": "Create a new Blok HTTP workflow"
	},
	"Cron Workflow": {
		"prefix": ["blok-workflow-cron", "workflow-cron"],
		"body": [
			"{",
			"\t\"name\": \"${1:scheduled-workflow}\",",
			"\t\"description\": \"${2:Runs on a schedule}\",",
			"\t\"version\": \"1.0.0\",",
			"\t\"trigger\": {",
			"\t\t\"cron\": {",
			"\t\t\t\"schedule\": \"${3:*/5 * * * *}\",",
			"\t\t\t\"timezone\": \"${4:UTC}\"",
			"\t\t}",
			"\t},",
			"\t\"steps\": [",
			"\t\t{",
			"\t\t\t\"name\": \"${5:task-step}\",",
			"\t\t\t\"node\": \"${6:./nodes/my-task}\",",
			"\t\t\t\"type\": \"local\"",
			"\t\t}",
			"\t],",
			"\t\"nodes\": {",
			"\t\t\"${5:task-step}\": {",
			"\t\t\t\"inputs\": {",
			"\t\t\t\t${7}",
			"\t\t\t}",
			"\t\t}",
			"\t}",
			"}"
		],
		"description": "Create a new Blok cron/scheduled workflow"
	},
	"Queue Workflow": {
		"prefix": ["blok-workflow-queue", "workflow-queue"],
		"body": [
			"{",
			"\t\"name\": \"${1:queue-consumer}\",",
			"\t\"description\": \"${2:Processes messages from queue}\",",
			"\t\"version\": \"1.0.0\",",
			"\t\"trigger\": {",
			"\t\t\"queue\": {",
			"\t\t\t\"provider\": \"${3|kafka,rabbitmq,sqs,redis,beanstalk|}\",",
			"\t\t\t\"topic\": \"${4:my-topic}\",",
			"\t\t\t\"consumerGroup\": \"${5:blok-workers}\"",
			"\t\t}",
			"\t},",
			"\t\"steps\": [",
			"\t\t{",
			"\t\t\t\"name\": \"${6:process-message}\",",
			"\t\t\t\"node\": \"${7:./nodes/message-handler}\",",
			"\t\t\t\"type\": \"local\"",
			"\t\t}",
			"\t],",
			"\t\"nodes\": {",
			"\t\t\"${6:process-message}\": {",
			"\t\t\t\"inputs\": {",
			"\t\t\t\t${8}",
			"\t\t\t}",
			"\t\t}",
			"\t}",
			"}"
		],
		"description": "Create a new Blok queue consumer workflow"
	},
	"Webhook Workflow": {
		"prefix": ["blok-workflow-webhook", "workflow-webhook"],
		"body": [
			"{",
			"\t\"name\": \"${1:webhook-handler}\",",
			"\t\"description\": \"${2:Handles incoming webhooks}\",",
			"\t\"version\": \"1.0.0\",",
			"\t\"trigger\": {",
			"\t\t\"webhook\": {",
			"\t\t\t\"source\": \"${3|github,stripe,shopify,custom|}\",",
			"\t\t\t\"events\": [\"${4:push}\"],",
			"\t\t\t\"secret\": \"${5:WEBHOOK_SECRET}\"",
			"\t\t}",
			"\t},",
			"\t\"steps\": [",
			"\t\t{",
			"\t\t\t\"name\": \"${6:handle-event}\",",
			"\t\t\t\"node\": \"${7:./nodes/webhook-handler}\",",
			"\t\t\t\"type\": \"local\"",
			"\t\t}",
			"\t],",
			"\t\"nodes\": {",
			"\t\t\"${6:handle-event}\": {",
			"\t\t\t\"inputs\": {",
			"\t\t\t\t\"event\": \"\\${ctx.request.body}\"",
			"\t\t\t}",
			"\t\t}",
			"\t}",
			"}"
		],
		"description": "Create a new Blok webhook handler workflow"
	},
	"Conditional Step": {
		"prefix": ["blok-condition", "workflow-if-else"],
		"body": [
			"{",
			"\t\"name\": \"${1:filter-step}\",",
			"\t\"node\": \"@blok/if-else\",",
			"\t\"type\": \"module\"",
			"}",
			"",
			"// In nodes section:",
			"\"${1:filter-step}\": {",
			"\t\"conditions\": [",
			"\t\t{",
			"\t\t\t\"type\": \"if\",",
			"\t\t\t\"condition\": \"${2:ctx.request.query.type === 'admin'}\",",
			"\t\t\t\"steps\": [",
			"\t\t\t\t{",
			"\t\t\t\t\t\"name\": \"${3:if-branch}\",",
			"\t\t\t\t\t\"node\": \"${4:./nodes/admin-handler}\",",
			"\t\t\t\t\t\"type\": \"local\"",
			"\t\t\t\t}",
			"\t\t\t]",
			"\t\t},",
			"\t\t{",
			"\t\t\t\"type\": \"else\",",
			"\t\t\t\"steps\": [",
			"\t\t\t\t{",
			"\t\t\t\t\t\"name\": \"${5:else-branch}\",",
			"\t\t\t\t\t\"node\": \"${6:./nodes/user-handler}\",",
			"\t\t\t\t\t\"type\": \"local\"",
			"\t\t\t\t}",
			"\t\t\t]",
			"\t\t}",
			"\t]",
			"}"
		],
		"description": "Add conditional branching (if/else) to a workflow"
	},
	"Workflow Step": {
		"prefix": ["blok-step", "workflow-step"],
		"body": [
			"{",
			"\t\"name\": \"${1:step-name}\",",
			"\t\"node\": \"${2:@blok/api-call}\",",
			"\t\"type\": \"${3|module,local,runtime.nodejs,runtime.python3,runtime.go,runtime.java,runtime.rust|}\"",
			"}"
		],
		"description": "Add a step to a Blok workflow"
	},
	"WebSocket Workflow": {
		"prefix": ["blok-workflow-websocket", "workflow-ws"],
		"body": [
			"{",
			"\t\"name\": \"${1:realtime-handler}\",",
			"\t\"description\": \"${2:Real-time WebSocket handler}\",",
			"\t\"version\": \"1.0.0\",",
			"\t\"trigger\": {",
			"\t\t\"websocket\": {",
			"\t\t\t\"path\": \"${3:/ws}\",",
			"\t\t\t\"events\": [\"message\", \"join\", \"leave\"],",
			"\t\t\t\"maxConnections\": ${4:1000}",
			"\t\t}",
			"\t},",
			"\t\"steps\": [",
			"\t\t{",
			"\t\t\t\"name\": \"${5:handle-message}\",",
			"\t\t\t\"node\": \"${6:./nodes/ws-handler}\",",
			"\t\t\t\"type\": \"local\"",
			"\t\t}",
			"\t],",
			"\t\"nodes\": {",
			"\t\t\"${5:handle-message}\": {",
			"\t\t\t\"inputs\": {",
			"\t\t\t\t${7}",
			"\t\t\t}",
			"\t\t}",
			"\t}",
			"}"
		],
		"description": "Create a new Blok WebSocket workflow"
	},
	"Worker Workflow": {
		"prefix": ["blok-workflow-worker", "workflow-worker"],
		"body": [
			"{",
			"\t\"name\": \"${1:background-job}\",",
			"\t\"description\": \"${2:Background job processing}\",",
			"\t\"version\": \"1.0.0\",",
			"\t\"trigger\": {",
			"\t\t\"worker\": {",
			"\t\t\t\"queue\": \"${3:job-queue}\",",
			"\t\t\t\"concurrency\": ${4:5},",
			"\t\t\t\"timeout\": ${5:30000},",
			"\t\t\t\"retries\": ${6:3}",
			"\t\t}",
			"\t},",
			"\t\"steps\": [",
			"\t\t{",
			"\t\t\t\"name\": \"${7:process-job}\",",
			"\t\t\t\"node\": \"${8:./nodes/job-processor}\",",
			"\t\t\t\"type\": \"local\"",
			"\t\t}",
			"\t],",
			"\t\"nodes\": {",
			"\t\t\"${7:process-job}\": {",
			"\t\t\t\"inputs\": {",
			"\t\t\t\t${9}",
			"\t\t\t}",
			"\t\t}",
			"\t}",
			"}"
		],
		"description": "Create a new Blok worker/background job workflow"
	}
}
