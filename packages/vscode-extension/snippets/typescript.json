{
	"Define Node (Function-First)": {
		"prefix": ["blok-node", "defineNode"],
		"body": [
			"import { defineNode } from \"@blokjs/runner\";",
			"import { z } from \"zod\";",
			"",
			"export default defineNode({",
			"\tname: \"${1:my-node}\",",
			"\tdescription: \"${2:Description of what this node does}\",",
			"",
			"\tinput: z.object({",
			"\t\t${3:field}: z.${4:string}(),",
			"\t}),",
			"",
			"\toutput: z.object({",
			"\t\t${5:result}: z.${6:string}(),",
			"\t}),",
			"",
			"\tasync execute(ctx, input) {",
			"\t\t${7:// Implement node logic}",
			"\t\treturn { ${5:result}: ${8:input.${3:field}} };",
			"\t},",
			"});"
		],
		"description": "Create a new Blok node using the function-first defineNode API with Zod schemas"
	},
	"Define Node with API Call": {
		"prefix": ["blok-node-api", "defineNode-api"],
		"body": [
			"import { defineNode } from \"@blokjs/runner\";",
			"import { z } from \"zod\";",
			"",
			"export default defineNode({",
			"\tname: \"${1:api-call-node}\",",
			"\tdescription: \"${2:Calls an external API}\",",
			"",
			"\tinput: z.object({",
			"\t\t${3:url}: z.string().url(),",
			"\t\t${4:method}: z.enum([\"GET\", \"POST\", \"PUT\", \"DELETE\"]).default(\"GET\"),",
			"\t}),",
			"",
			"\toutput: z.object({",
			"\t\tdata: z.unknown(),",
			"\t\tstatus: z.number(),",
			"\t}),",
			"",
			"\tasync execute(ctx, input) {",
			"\t\tconst response = await fetch(input.${3:url}, {",
			"\t\t\tmethod: input.${4:method},",
			"\t\t\theaders: { \"Content-Type\": \"application/json\" },",
			"\t\t});",
			"",
			"\t\tconst data = await response.json();",
			"\t\treturn { data, status: response.status };",
			"\t},",
			"});"
		],
		"description": "Create a Blok node that makes HTTP API calls"
	},
	"Define Node with Database": {
		"prefix": ["blok-node-db", "defineNode-db"],
		"body": [
			"import { defineNode } from \"@blokjs/runner\";",
			"import { z } from \"zod\";",
			"",
			"export default defineNode({",
			"\tname: \"${1:db-query-node}\",",
			"\tdescription: \"${2:Queries the database}\",",
			"",
			"\tinput: z.object({",
			"\t\t${3:id}: z.string().uuid(),",
			"\t}),",
			"",
			"\toutput: z.object({",
			"\t\t${4:record}: z.object({",
			"\t\t\tid: z.string(),",
			"\t\t\t${5:name}: z.string(),",
			"\t\t\tcreatedAt: z.string().datetime(),",
			"\t\t}),",
			"\t}),",
			"",
			"\tasync execute(ctx, input) {",
			"\t\t// Use ctx.vars or ctx.env for database config",
			"\t\tconst ${4:record} = { id: input.${3:id}, ${5:name}: \"${6:example}\", createdAt: new Date().toISOString() };",
			"\t\treturn { ${4:record} };",
			"\t},",
			"});"
		],
		"description": "Create a Blok node that performs database operations"
	},
	"Class-Based Node (Legacy)": {
		"prefix": ["blok-node-class", "blok"],
		"body": [
			"import { BlokService, BlokResponse, type IBlokResponse } from \"@blokjs/runner\";",
			"import type { Context, GlobalError } from \"@blokjs/shared\";",
			"",
			"interface ${1:MyNode}Input {",
			"\t${2:field}: ${3:string};",
			"}",
			"",
			"export default class ${1:MyNode} extends BlokService<${1:MyNode}Input> {",
			"\tconstructor() {",
			"\t\tsuper();",
			"\t\tthis.inputSchema = {",
			"\t\t\ttype: \"object\",",
			"\t\t\tproperties: {",
			"\t\t\t\t${2:field}: { type: \"${3:string}\" },",
			"\t\t\t},",
			"\t\t\trequired: [\"${2:field}\"],",
			"\t\t};",
			"\t}",
			"",
			"\tasync handle(ctx: Context, inputs: ${1:MyNode}Input): Promise<IBlokResponse> {",
			"\t\tconst response = new BlokResponse();",
			"\t\ttry {",
			"\t\t\t${4:// Implement node logic}",
			"\t\t\tresponse.setSuccess({ ${2:field}: inputs.${2:field} });",
			"\t\t} catch (error: unknown) {",
			"\t\t\tconst err = error as Error;",
			"\t\t\tconst globalError = { message: err.message } as GlobalError;",
			"\t\t\tresponse.setError(globalError);",
			"\t\t}",
			"\t\treturn response;",
			"\t}",
			"}"
		],
		"description": "Create a legacy class-based Blok node (prefer defineNode instead)"
	},
	"Node Test (TestHarness)": {
		"prefix": ["blok-test", "blok-node-test"],
		"body": [
			"import { describe, it, expect } from \"vitest\";",
			"import { NodeTestHarness, TestLogger } from \"@blokjs/runner\";",
			"import ${1:MyNode} from \"./${2:my-node}\";",
			"",
			"describe(\"${1:MyNode}\", () => {",
			"\tconst harness = new NodeTestHarness(${1:MyNode});",
			"",
			"\tit(\"should ${3:process input correctly}\", async () => {",
			"\t\tconst result = await harness.execute({",
			"\t\t\t${4:field}: ${5:\"test-value\"},",
			"\t\t});",
			"",
			"\t\tharness.assertSuccess(result);",
			"\t\texpect(result.data).toHaveProperty(\"${6:result}\");",
			"\t});",
			"",
			"\tit(\"should handle errors\", async () => {",
			"\t\tconst result = await harness.execute({",
			"\t\t\t${4:field}: ${7:\"\"},",
			"\t\t});",
			"",
			"\t\tharness.assertError(result);",
			"\t});",
			"});"
		],
		"description": "Create a test for a Blok node using TestHarness"
	},
	"Workflow Test (WorkflowTestRunner)": {
		"prefix": ["blok-workflow-test"],
		"body": [
			"import { describe, it, expect } from \"vitest\";",
			"import { WorkflowTestRunner } from \"@blokjs/runner\";",
			"",
			"describe(\"${1:My Workflow}\", () => {",
			"\tconst runner = new WorkflowTestRunner();",
			"",
			"\tit(\"should execute successfully\", async () => {",
			"\t\trunner.mockNode(\"${2:step-name}\", async (ctx, input) => ({",
			"\t\t\t${3:result}: \"mocked\",",
			"\t\t}));",
			"",
			"\t\tconst result = await runner.execute(\"${4:./workflows/json/${5:my-workflow}.json}\", {",
			"\t\t\tbody: { ${6:key}: ${7:\"value\"} },",
			"\t\t});",
			"",
			"\t\texpect(result.success).toBe(true);",
			"\t\trunner.assertNodeExecuted(result, \"${2:step-name}\");",
			"\t});",
			"});"
		],
		"description": "Create a workflow test using WorkflowTestRunner"
	}
}
