{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2022",
		"outDir": "dist",
		"rootDir": "src",
		"lib": ["ES2022"],
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"declaration": true,
		"moduleResolution": "node"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "**/__tests__/**"]
}
