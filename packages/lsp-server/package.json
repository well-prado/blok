{
	"name": "@blok/lsp-server",
	"version": "0.1.0",
	"description": "Language Server Protocol server for Blok workflow files - provides diagnostics, completion, and hover documentation for any LSP-compatible editor",
	"license": "Apache-2.0",
	"main": "./dist/server.js",
	"bin": {
		"blok-lsp": "./dist/server.js"
	},
	"scripts": {
		"build": "tsc",
		"watch": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"vscode-languageserver": "^9.0.1",
		"vscode-languageserver-textdocument": "^1.0.12"
	},
	"devDependencies": {
		"@types/node": "^20.10.0",
		"typescript": "^5.3.2",
		"vitest": "^2.0.0"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"keywords": [
		"blok",
		"lsp",
		"language-server",
		"workflow",
		"json",
		"blok"
	]
}
