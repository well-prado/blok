{
	"name": "blokctl",
	"version": "0.2.11",
	"author": "Deskree Technologies Inc.",
	"license": "Apache-2.0",
	"description": "cli for blok",
	"engines": {
		"node": ">=18.0.0"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"bin": {
		"blokctl": "./dist/index.js"
	},
	"files": ["dist", "node_modules"],
	"scripts": {
		"build": "rm -rf dist && bun run tsc",
		"build:dev": "tsc --watch",
		"test:dev": "vitest",
		"test": "vitest run",
		"typecheck": "tsc --noEmit --incremental",
		"clean": "rm -rf dist && rm -rf node_modules",
		"install:local": "npm link",
		"uninstall:local": "npm rm --global blokctl",
		"dev": "npm run uninstall:local && npm run install:local && npm run build:dev && blokctl --help",
		"postbuild": "cp -r ./src/commands/monitor/static ./dist/commands/monitor/ && if [ -d ../../apps/studio/dist ]; then cp -r ../../apps/studio/dist ./dist/studio-dist; fi",
		"build:studio": "bun run --filter @blokjs/studio build && cp -r ../../apps/studio/dist ./dist/studio-dist"
	},
	"keywords": ["blokctl", "cli", "blok", "blok"],
	"dependencies": {
		"@ai-sdk/openai": "^1.3.22",
		"@blokjs/runner": "^0.2.0",
		"@clack/prompts": "^1.0.0",
		"ai": "^4.3.16",
		"better-sqlite3": "^12.6.2",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"express": "^4.21.2",
		"fast-glob": "^3.3.3",
		"figlet": "^1.10.0",
		"fs-extra": "^11.3.3",
		"ink": "^5.2.1",
		"open": "^11.0.0",
		"picocolors": "^1.1.1",
		"pluralize": "^8.0.0",
		"posthog-node": "^4.6.0",
		"react": "^18.3.0",
		"serve-handler": "^6.1.6",
		"simple-git": "^3.30.0",
		"type-fest": "^4.34.1",
		"typescript": "^5.8.3",
		"yocto-spinner": "^1.0.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@types/express": "^4.17.21",
		"@types/figlet": "^1.7.0",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^22.15.21",
		"@types/pluralize": "^0.0.33",
		"@types/react": "^19.2.10",
		"rimraf": "^6.1.2",
		"vitest": "^4.0.18"
	},
	"private": false,
	"publishConfig": {
		"access": "public"
	}
}
