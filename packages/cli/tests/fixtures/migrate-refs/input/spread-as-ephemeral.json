{
	"name": "Spread/as/ephemeral edge",
	"version": "1.0.0",
	"trigger": {
		"http": {
			"method": "POST",
			"path": "/edge",
			"accept": "application/json"
		}
	},
	"steps": [
		{
			"id": "split",
			"use": "splitter",
			"spread": true,
			"inputs": {
				"body": "js/ctx.request.body"
			}
		},
		{
			"id": "loop",
			"forEach": {
				"in": "js/ctx.request.body.items",
				"as": "item",
				"do": [
					{
						"id": "inner",
						"use": "sink",
						"inputs": {
							"item": "js/ctx.state.item",
							"userName": "js/ctx.state.user.name"
						}
					}
				]
			}
		},
		{
			"id": "mixed-template",
			"use": "sink",
			"inputs": {
				"message": "js/`user:${ctx.state.user.name} flag:${ctx.request.body.flag || 'n'}`"
			}
		},
		{
			"id": "scratch",
			"use": "audit",
			"ephemeral": true,
			"inputs": {
				"note": "js/ctx.request.body.note"
			}
		},
		{
			"id": "after-scratch",
			"use": "sink",
			"inputs": {
				"prev": "js/ctx.prev.value"
			}
		}
	]
}
