{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Blok Workflow",
	"scopeName": "source.blok-workflow",
	"fileTypes": ["workflow.json"],
	"patterns": [
		{ "include": "#top-level-keys" },
		{ "include": "#trigger-types" },
		{ "include": "#http-methods" },
		{ "include": "#step-properties" },
		{ "include": "#runtime-kinds" },
		{ "include": "#condition-keywords" },
		{ "include": "#node-references" },
		{ "include": "source.json" }
	],
	"repository": {
		"top-level-keys": {
			"match": "\"(name|version|description|trigger|steps|nodes)\"\\s*:",
			"captures": {
				"1": { "name": "keyword.control.blok" }
			}
		},
		"trigger-types": {
			"match": "\"(http|cron|webhook|websocket|queue|grpc|pubsub|sse|worker|manual)\"\\s*:",
			"captures": {
				"1": { "name": "entity.name.tag.trigger.blok" }
			}
		},
		"http-methods": {
			"match": "\"(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS)\"",
			"captures": {
				"1": { "name": "constant.language.http-method.blok" }
			}
		},
		"step-properties": {
			"match": "\"(node|type|runtime|conditions|inputs|outputs|method|path|schedule|source|events|provider|topic|service|expression)\"\\s*:",
			"captures": {
				"1": { "name": "support.type.property-name.blok" }
			}
		},
		"runtime-kinds": {
			"match": "\"(local|module|runtime\\.nodejs|runtime\\.python3|runtime\\.go|runtime\\.java|runtime\\.rust|runtime\\.php|runtime\\.csharp|runtime\\.ruby|runtime\\.bun|runtime\\.wasm|runtime\\.docker)\"",
			"captures": {
				"1": { "name": "constant.other.runtime-kind.blok" }
			}
		},
		"condition-keywords": {
			"match": "\"(if|else|else-if|switch|case)\"",
			"captures": {
				"1": { "name": "keyword.control.flow.blok" }
			}
		},
		"node-references": {
			"match": "\"node\"\\s*:\\s*\"([^\"]+)\"",
			"captures": {
				"1": { "name": "entity.name.type.node-ref.blok" }
			}
		}
	}
}
