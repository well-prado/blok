{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"ignore": [
			"node_modules",
			".claude/**",
			"dist",
			".nx/**",
			"**/routeTree.gen.ts",
			"sdks/*/vendor/**",
			"sdks/*/.venv/**",
			"sdks/python3/**/__pycache__/**"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noThenProperty": "off"
			}
		}
	},
	"overrides": [
		{
			"include": [
				"**/__tests__/**/*.ts",
				"**/tests/**/*.ts",
				"**/*.test.ts",
				"**/*.spec.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					},
					"complexity": {
						"noForEach": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"lineWidth": 120
		}
	}
}
