{
	"name": "blok",
	"version": "0.1.0",
	"description": "",
	"keywords": [],
	"author": "Deskree Technologies Inc.",
	"license": "Apache-2.0",
	"workspaces": [
		"core/*",
		"nodes/**/**",
		"triggers/*",
		"templates/**/**",
		"packages/*",
		"apps/*"
	],
	"trustedDependencies": [
		"@biomejs/biome",
		"@bufbuild/buf",
		"better-sqlite3",
		"esbuild",
		"nx",
		"protobufjs"
	],
	"scripts": {
		"ci:publish": "bun run build && bunx changeset publish",
		"doc:dev": "cd docs && bunx mintlify dev",
		"doc:generate": "bunx typedoc --skipErrorChecking && bun run ./docs/generateRefLinks.js",
		"prepare": "husky",
		"lint": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
		"test": "nx run-many -t test",
		"cli:dev": "bun run --filter blokctl build:dev",
		"cli:test:dev": "bun run --filter blokctl test:dev",
		"cli:test": "bun run --filter blokctl test",
		"build:cli": "bun run --filter blokctl build",
		"runner:test": "bun run --filter @blokjs/runner test:dev",
		"runner:dev": "bun run --filter @blokjs/runner build:dev",
		"helper:test": "bun run --filter @blokjs/helper test:dev",
		"helper:dev": "bun run --filter @blokjs/helper build:dev",
		"http:dev": "bun run --filter @blokjs/trigger-http dev",
		"nodes:build": "bun run --filter @blokjs/api-call --filter @blokjs/if-else --filter @blokjs/react --filter node-name --filter node-ui-name build:dev",
		"core:build:dev": "bun run --filter @blokjs/runner --filter @blokjs/shared --filter @blokjs/helper build:dev",
		"build": "bun run --filter @blokjs/shared --filter @blokjs/helper build && bun run --filter @blokjs/runner build && bun run --filter blokctl --filter @blokjs/api-call --filter @blokjs/if-else --filter @blokjs/react --filter node-name --filter node-ui-name build"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@changesets/cli": "^2.29.8",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"nx": "20.8.4",
		"typedoc": "^0.28.16",
		"typedoc-plugin-markdown": "^4.9.0"
	},
	"lint-staged": {
		"*": [
			"biome check --unsafe --write --no-errors-on-unmatched --files-ignore-unknown=true",
			"bun run test"
		]
	},
	"private": true
}
