{
	"name": "blok",
	"version": "0.1.0",
	"description": "",
	"keywords": [],
	"author": "Deskree Technologies Inc.",
	"license": "Apache-2.0",
	"workspaces": [
		"core/*",
		"nodes/**/**",
		"triggers/*",
		"templates/**/**",
		"packages/*",
		"apps/*"
	],
	"trustedDependencies": [
		"@biomejs/biome",
		"@bufbuild/buf",
		"better-sqlite3",
		"esbuild",
		"nx",
		"protobufjs"
	],
	"scripts": {
		"ci:publish": "bun run build && bunx changeset publish",
		"release": "bun run scripts/release.ts",
		"doc:dev": "cd docs && bunx mint@latest dev",
		"doc:generate": "bunx typedoc --skipErrorChecking && bun run ./docs/generateRefLinks.js",
		"prepare": "husky",
		"lint": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
		"lint:check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
		"proto:sync": "bun run scripts/sync-proto.ts",
		"proto:check": "bun run scripts/sync-proto.ts --check",
		"test": "nx run-many -t test",
		"test:coverage": "nx run-many -t test -p @blokjs/runner @blokjs/shared @blokjs/trigger-grpc @blokjs/trigger-sse @blokjs/trigger-websocket -- --coverage",
		"test:integration": "bash scripts/integration-test.sh",
		"test:integration:up": "docker compose -f infra/testing/docker-compose.yml up -d",
		"test:integration:down": "docker compose -f infra/testing/docker-compose.yml down -v",
		"ci": "bash scripts/ci-local.sh integration",
		"ci:fast": "bash scripts/ci-local.sh fast",
		"ci:cross-runtime": "bash scripts/ci-local.sh cross-runtime",
		"ci:all": "bash scripts/ci-local.sh all",
		"cli:dev": "bun run --filter blokctl build:dev",
		"cli:test:dev": "bun run --filter blokctl test:dev",
		"cli:test": "bun run --filter blokctl test",
		"build:cli": "bun run --filter blokctl build",
		"runner:test": "bun run --filter @blokjs/runner test:dev",
		"runner:dev": "bun run --filter @blokjs/runner build:dev",
		"helper:test": "bun run --filter @blokjs/helper test:dev",
		"helper:dev": "bun run --filter @blokjs/helper build:dev",
		"http:dev": "bun run build && bun run --filter @blokjs/trigger-http dev",
		"dev": "bun run scripts/dev-full.ts",
		"v05:smoke": "bun run build && bun run scripts/v05-smoke.ts",
		"sdks:build": "bash scripts/sdks-build.sh",
		"nodes:build": "bun run --filter @blokjs/api-call --filter @blokjs/if-else --filter @blokjs/react --filter @blokjs/helpers --filter node-name --filter node-ui-name build:dev",
		"core:build:dev": "bun run --filter @blokjs/runner --filter @blokjs/shared --filter @blokjs/helper build:dev",
		"build": "bunx nx run-many -t build"
	},
	"devDependencies": {
		"@aws-sdk/client-sns": "^3.981.0",
		"@aws-sdk/client-sqs": "^3.981.0",
		"@azure/service-bus": "^7.9.5",
		"@biomejs/biome": "1.9.4",
		"@changesets/cli": "^2.29.8",
		"@google-cloud/pubsub": "^5.2.2",
		"amqplib": "^0.10.9",
		"bullmq": "^5.67.2",
		"husky": "^9.1.7",
		"ioredis": "^5.9.2",
		"kafkajs": "^2.2.4",
		"lint-staged": "^16.2.7",
		"nats": "^2.29.3",
		"nx": "20.8.4",
		"typedoc": "^0.28.16",
		"typedoc-plugin-markdown": "^4.9.0"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"private": true
}
