{
	"name": "@blokjs/core",
	"version": "1.1.0",
	"description": "Blok's typed-handle authoring DSL — the published author import surface (workflow/step/branch/http/tpl/comparators).",
	"engines": {
		"node": ">=18.0.0"
	},
	"type": "module",
	"sideEffects": false,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./dsl": {
			"types": "./dist/dsl.d.ts",
			"import": "./dist/dsl.js",
			"default": "./dist/dsl.js"
		},
		"./runtime": {
			"types": "./dist/runtime.d.ts",
			"import": "./dist/runtime.js",
			"default": "./dist/runtime.js"
		},
		"./testing": {
			"types": "./dist/testing.d.ts",
			"import": "./dist/testing.js",
			"default": "./dist/testing.js"
		},
		"./package.json": "./package.json"
	},
	"files": ["dist"],
	"author": "Deskree Technologies Inc.",
	"license": "MIT",
	"scripts": {
		"build": "rm -rf dist && bun run tsc",
		"build:dev": "tsc --watch",
		"test:dev": "vitest",
		"test": "vitest run",
		"typecheck": "tsc --noEmit --incremental"
	},
	"devDependencies": {
		"@types/node": "^22.15.21",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@blokjs/helper": "^1.1.0",
		"@blokjs/runner": "^1.1.0",
		"@blokjs/shared": "^1.1.0",
		"zod": "^3.24.2"
	},
	"private": false,
	"publishConfig": {
		"access": "public"
	}
}
