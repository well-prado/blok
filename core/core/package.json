{
	"name": "@blokjs/core",
	"version": "0.7.0",
	"description": "Blok's typed-handle authoring DSL — the published author import surface (workflow/step/branch/http/tpl/comparators).",
	"engines": {
		"node": ">=18.0.0"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"author": "Deskree Technologies Inc.",
	"license": "MIT",
	"scripts": {
		"build": "rm -rf dist && bun run tsc",
		"build:dev": "tsc --watch",
		"test:dev": "vitest",
		"test": "vitest run",
		"typecheck": "tsc --noEmit --incremental"
	},
	"devDependencies": {
		"@types/node": "^22.15.21",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@blokjs/helper": "^0.7.0",
		"@blokjs/runner": "^0.7.0",
		"@blokjs/shared": "^0.7.0",
		"zod": "^3.24.2"
	},
	"private": false,
	"publishConfig": {
		"access": "public"
	}
}
