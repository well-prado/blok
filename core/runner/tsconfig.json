{
	"compilerOptions": {
		"target": "es2022",
		"module": "es2022",
		"moduleResolution": "bundler",
		"rootDir": "./src",
		"declaration": true,
		"sourceMap": true,
		"outDir": "./dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noUnusedLocals": true,
		"noImplicitReturns": true,
		"skipLibCheck": true
	},
	"compileOnSave": true,
	"include": ["./src"],
	"exclude": [
		"./src/**/__tests__",
		"./src/**/__type-tests__",
		"./src/**/*.test.ts",
		"./test"
	]
}
