{
	"name": "@blokjs/trigger-pubsub",
	"version": "0.2.1",
	"description": "Pub/Sub-based trigger for Blok workflows - supports GCP Pub/Sub, AWS SNS/SQS, and Azure Service Bus",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "rm -rf dist && bun run tsc",
		"build:dev": "tsc --watch",
		"test": "vitest run",
		"test:dev": "vitest"
	},
	"author": "Deskree Technologies Inc.",
	"license": "Apache-2.0",
	"dependencies": {
		"@blokjs/helper": "^0.2.0",
		"@blokjs/runner": "^0.2.0",
		"@blokjs/shared": "^0.2.0",
		"@opentelemetry/api": "^1.9.0",
		"uuid": "^11.1.0"
	},
	"devDependencies": {
		"@types/node": "^22.15.21",
		"@types/uuid": "^11.0.0",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"@google-cloud/pubsub": "^4.0.0",
		"@aws-sdk/client-sns": "^3.980.0",
		"@aws-sdk/client-sqs": "^3.980.0",
		"@azure/service-bus": "^7.9.5"
	},
	"peerDependenciesMeta": {
		"@google-cloud/pubsub": {
			"optional": true
		},
		"@aws-sdk/client-sns": {
			"optional": true
		},
		"@aws-sdk/client-sqs": {
			"optional": true
		},
		"@azure/service-bus": {
			"optional": true
		}
	},
	"private": false,
	"publishConfig": {
		"access": "public"
	}
}
