{
	"name": "@nanoservice-ts/trigger-pubsub",
	"version": "0.0.1",
	"description": "Pub/Sub-based trigger for Blok workflows - supports GCP Pub/Sub, AWS SNS/SQS, and Azure Service Bus",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "rm -rf dist && npx tsc",
		"build:dev": "tsc --watch",
		"test": "vitest run",
		"test:dev": "vitest"
	},
	"author": "Deskree Technologies Inc.",
	"license": "Apache-2.0",
	"dependencies": {
		"@nanoservice-ts/helper": "workspace:*",
		"@nanoservice-ts/runner": "workspace:*",
		"@nanoservice-ts/shared": "workspace:*",
		"@opentelemetry/api": "^1.8.0",
		"uuid": "^10.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.13.14",
		"@types/uuid": "^10.0.0",
		"typescript": "^5.1.3",
		"vitest": "^3.1.4"
	},
	"peerDependencies": {
		"@google-cloud/pubsub": "^4.0.0",
		"@aws-sdk/client-sns": "^3.700.0",
		"@aws-sdk/client-sqs": "^3.700.0",
		"@azure/service-bus": "^7.9.0"
	},
	"peerDependenciesMeta": {
		"@google-cloud/pubsub": {
			"optional": true
		},
		"@aws-sdk/client-sns": {
			"optional": true
		},
		"@aws-sdk/client-sqs": {
			"optional": true
		},
		"@azure/service-bus": {
			"optional": true
		}
	}
