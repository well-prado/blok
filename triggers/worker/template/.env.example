PROJECT_NAME=trigger-worker-server
PROJECT_VERSION=0.0.1
WORKFLOWS_PATH=PROJECT_PATH/workflows
NODES_PATH=PROJECT_PATH/src/nodes
CONSOLE_LOG_ACTIVE=true
APP_NAME=blok-worker
DISABLE_TRIGGER_RUN=false # Set to true to disable trigger run and use this project as a module

# Worker adapter — resolved per-workflow via `trigger.worker.provider`, then
# BLOK_WORKER_ADAPTER, then `in-memory`. The in-memory adapter is per-process
# (dev only); for production set a broker (nats / bullmq / rabbitmq / sqs /
# pg-boss / kafka) here and supply its connection env below.
BLOK_WORKER_ADAPTER=in-memory

# NATS JetStream (only needed when BLOK_WORKER_ADAPTER=nats)
# NATS_SERVERS=localhost:4222
# NATS_STREAM_NAME=blok-worker
# NATS_TOKEN=your-auth-token
