		"@opentelemetry/api": "^1.9.0",
		"uuid": "^11.1.0"
	},
	"devDependencies": {
		"@types/node": "^22.15.21",
		"@types/uuid": "^11.0.0",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"bullmq": "^5.67.2",
		"ioredis": "^5.9.2"
