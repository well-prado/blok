	"description": "Worker-based trigger for Blok workflows - supports background job processing with concurrency, retries, and scheduling",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "rm -rf dist && bun run tsc",
