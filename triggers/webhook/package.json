	"license": "Apache-2.0",
	"dependencies": {
		"@blokjs/helper": "^0.4.0",
		"@blokjs/runner": "^0.4.0",
		"@blokjs/shared": "^0.4.0",
		"@opentelemetry/api": "^1.9.0",
		"uuid": "^11.1.0"
	},
	"devDependencies": {
		"@types/node": "^22.15.21",
		"@types/uuid": "^11.0.0",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	},
	"private": false,
	"publishConfig": {
		"access": "public"
