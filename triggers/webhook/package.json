{
	"name": "@blokjs/trigger-webhook",
	"version": "0.2.1",
	"description": "Webhook trigger for Blok workflows - supports GitHub, Stripe, Shopify, and custom webhooks",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "rm -rf dist && bun run tsc",
