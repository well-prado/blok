		"@hono/node-ws": "^1.3.1",
		"@opentelemetry/api": "^1.9.0",
		"uuid": "^11.1.0"
	},
	"peerDependencies": {
		"@blokjs/trigger-pubsub": "^0.6.8",
		"ws": "^8.19.0"
	},
