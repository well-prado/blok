{
	"name": "Films Workflow",
	"version": "1.0.0",
	"description": "This workflow returns a list of films from Postgres",
	"trigger": {
		"http": {
			"method": "GET",
			"path": "/",
			"accept": "application/json"
		}
	},
	"steps": [
		{
			"id": "get-films",
			"use": "postgres-query",
			"type": "module",
			"inputs": {
				"host": "localhost",
				"port": 5432,
				"database": "dvdrental",
				"user": "postgres",
				"password": "example",
				"query": "SELECT * FROM \"film\" ORDER BY \"title\" LIMIT 50"
			}
		}
	]
}
