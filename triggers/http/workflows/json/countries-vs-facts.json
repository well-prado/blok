{
	"name": "Movies or Countries",
	"version": "1.0.0",
	"description": "Workflow description",
	"trigger": {
		"http": {
			"method": "GET",
			"path": "/countries-vs-facts",
			"accept": "application/json"
		}
	},
	"steps": [
		{
			"id": "filter-request",
			"branch": {
				"when": "ctx.request.query.countries === \"true\"",
				"then": [
					{
						"id": "get-countries",
						"use": "@blokjs/api-call",
						"type": "module"
					}
				],
				"else": [
					{
						"id": "get-facts",
						"use": "@blokjs/api-call",
						"type": "module"
					}
				]
			}
		}
	]
}
