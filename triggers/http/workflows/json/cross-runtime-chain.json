{
	"name": "Cross-Runtime Chain Test",
	"version": "1.2.0",
	"description": "Tests all 8 language runtimes by chaining nodes via ctx.vars. Each SDK node appends its language to the chain array. A final verify node confirms all runtimes executed correctly.",
	"trigger": {
		"http": {
			"method": "POST",
			"path": "/cross-runtime-chain",
			"accept": "application/json"
		}
	},
	"steps": [
		{
			"id": "init",
			"use": "chain-init",
			"type": "module",
			"inputs": {}
		},
		{
			"id": "go",
			"use": "chain-test",
			"type": "runtime.go",
			"inputs": {
				"chain": "js/ctx.vars['init'].chain",
				"origin": "js/ctx.vars['init'].origin"
			}
		},
		{
			"id": "rust",
			"use": "chain-test",
			"type": "runtime.rust",
			"inputs": {
				"chain": "js/ctx.vars['go'].chain",
				"origin": "js/ctx.vars['go'].origin"
			}
		},
		{
			"id": "java",
			"use": "chain-test",
			"type": "runtime.java",
			"inputs": {
				"chain": "js/ctx.vars['rust'].chain",
				"origin": "js/ctx.vars['rust'].origin"
			}
		},
		{
			"id": "csharp",
			"use": "chain-test",
			"type": "runtime.csharp",
			"inputs": {
				"chain": "js/ctx.vars['java'].chain",
				"origin": "js/ctx.vars['java'].origin"
			}
		},
		{
			"id": "php",
			"use": "chain-test",
			"type": "runtime.php",
			"inputs": {
				"chain": "js/ctx.vars['csharp'].chain",
				"origin": "js/ctx.vars['csharp'].origin"
			}
		},
		{
			"id": "ruby",
			"use": "chain-test",
			"type": "runtime.ruby",
			"inputs": {
				"chain": "js/ctx.vars['php'].chain",
				"origin": "js/ctx.vars['php'].origin"
			}
		},
		{
			"id": "python",
			"use": "chain-test",
			"type": "runtime.python3",
			"inputs": {
				"chain": "js/ctx.vars['ruby'].chain",
				"origin": "js/ctx.vars['ruby'].origin"
			}
		},
		{
			"id": "verify",
			"use": "chain-verify",
			"type": "module",
			"inputs": {}
		}
	]
}
