{
	"name": "v05-order-fulfillment",
	"version": "1.0.0",
	"description": "v0.5 showcase — combines all five primitives in one workflow. Trigger-level middleware (auth-check + rate-limit) gates entry; switch routes by order type (physical/subscription do parallel forEach over inventory ops, digital generates a license); tryCatch wraps the payment step with a finally-arm audit; the final expr step shapes the response. External calls go to httpbin.org so the workflow runs without secrets — pass `paymentUrl: https://httpbin.org/status/500` to force the failure path. Demonstrates: middleware chain, switch with array `when`, forEach parallel + concurrency, tryCatch with all three arms, $.error proxy in catch.",
	"trigger": {
		"http": {
			"method": "POST",
			"path": "/",
			"accept": "application/json",
			"middleware": ["auth-check", "rate-limit"]
		}
	},
	"steps": [
		{
			"id": "validate-body",
			"use": "@blokjs/json-schema",
			"type": "module",
			"inputs": {
				"schema": {
					"type": "object",
					"required": [
						"id",
						"type",
						"items",
						"total",
						"currency",
						"paymentUrl"
					],
					"properties": {
						"id": { "type": "string" },
						"type": { "type": "string" },
						"items": { "type": "array" },
						"total": { "type": "number" },
						"currency": { "type": "string" },
						"paymentUrl": { "type": "string" }
					}
				},
				"data": "js/ctx.request.body"
			}
		},
		{
			"id": "route-by-type",
			"switch": {
				"on": "js/ctx.request.body.type",
				"cases": [
					{
						"when": ["physical", "subscription"],
						"do": [
							{
								"id": "process-items",
								"forEach": {
									"in": "js/ctx.request.body.items",
									"as": "item",
									"mode": "parallel",
									"concurrency": 5,
									"do": [
										{
											"id": "inventory-check",
											"use": "@blokjs/api-call",
											"type": "module",
											"inputs": {
												"url": "https://httpbin.org/post",
												"method": "POST",
												"headers": {
													"Content-Type": "application/json",
													"X-Op": "inventory-check"
												},
												"body": {
													"sku": "js/ctx.state.item.sku",
													"qty": "js/ctx.state.item.quantity"
												},
												"responseType": "application/json"
											}
										}
									]
								}
							},
							{
								"id": "mark-non-digital",
								"use": "@blokjs/ctx-publish",
								"type": "module",
								"inputs": {
									"name": "licensed",
									"value": false
								}
							}
						]
					},
					{
						"when": "digital",
						"do": [
							{
								"id": "generate-license",
								"use": "@blokjs/api-call",
								"type": "module",
								"inputs": {
									"url": "https://httpbin.org/post",
									"method": "POST",
									"headers": {
										"Content-Type": "application/json",
										"X-Op": "license-create"
									},
									"body": {
										"orderId": "js/ctx.request.body.id",
										"items": "js/ctx.request.body.items"
									},
									"responseType": "application/json"
								}
							},
							{
								"id": "mark-licensed",
								"use": "@blokjs/ctx-publish",
								"type": "module",
								"inputs": {
									"name": "licensed",
									"value": true
								}
							}
						]
					}
				],
				"default": [
					{
						"id": "reject-unknown-type",
						"use": "@blokjs/throw",
						"type": "module",
						"inputs": {
							"message": "Unknown order type",
							"code": 400,
							"name": "BadOrderTypeError",
							"body": {
								"error": "Unknown order type",
								"hint": "type must be one of physical, subscription, digital"
							}
						}
					}
				]
			}
		},
		{
			"id": "charge-payment",
			"tryCatch": {
				"try": [
					{
						"id": "stripe-charge",
						"use": "@blokjs/api-call",
						"type": "module",
						"inputs": {
							"url": "js/ctx.request.body.paymentUrl",
							"method": "POST",
							"headers": {
								"Content-Type": "application/json",
								"X-Op": "stripe-charge"
							},
							"body": {
								"orderId": "js/ctx.request.body.id",
								"amount": "js/ctx.request.body.total",
								"currency": "js/ctx.request.body.currency"
							},
							"responseType": "application/json"
						}
					}
				],
				"catch": [
					{
						"id": "record-failure",
						"use": "@blokjs/ctx-publish",
						"type": "module",
						"inputs": {
							"name": "failureReason",
							"value": "js/ctx.error.message"
						}
					}
				],
				"finally": [
					{
						"id": "audit-outcome",
						"use": "@blokjs/audit-log",
						"type": "module",
						"inputs": {
							"event": "order-fulfillment",
							"orderId": "js/ctx.request.body.id",
							"total": "js/ctx.request.body.total",
							"identity": "js/ctx.state.identity"
						}
					}
				]
			}
		},
		{
			"id": "respond",
			"use": "@blokjs/expr",
			"type": "module",
			"inputs": {
				"expression": "({ orderId: ctx.request.body.id, type: ctx.request.body.type, outcome: ctx.state.failureReason ? 'failed' : 'success', itemsProcessed: Array.isArray(ctx.state['process-items']) ? ctx.state['process-items'].length : 0, licensed: ctx.state.licensed === true, failureReason: ctx.state.failureReason })"
			}
		}
	]
}
