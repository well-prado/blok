{
	"name": "Dashboard Charts Generator",
	"version": "1.0.0",
	"description": "This workflow generates multiple dashboard charts based using a postgreSQL database and AI prompts.",
	"trigger": {
		"http": {
			"method": "ANY",
			"path": "/:function?/:id?",
			"accept": "application/json"
		}
	},
	"steps": [
		{
			"id": "filter-request",
			"branch": {
				"when": "ctx.request.method.toLowerCase() === \"get\" && ctx.request.params.function === ''",
				"then": [
					{
						"id": "dashboard-ui",
						"use": "dashboard-ui",
						"type": "module"
					}
				],
				"else": [
					{
						"id": "method-not-allowed",
						"use": "error",
						"type": "module"
					}
				]
			}
		}
	]
}
