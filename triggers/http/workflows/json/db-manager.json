{
	"name": "Database Manager",
	"version": "1.0.0",
	"description": "This workflow is used to query a database using an AI Prompt UI",
	"trigger": {
		"http": {
			"method": "ANY",
			"path": "/:function?",
			"accept": "application/json"
		}
	},
	"steps": [
		{
			"id": "filter-request",
			"branch": {
				"when": "ctx.request.method.toLowerCase() === \"get\" && ctx.request.params.function === undefined",
				"then": [
					{
						"id": "database-ui",
						"use": "database-ui",
						"type": "module"
					}
				],
				"else": [
					{
						"id": "method-not-allowed",
						"use": "error",
						"type": "module"
					}
				]
			}
		}
	]
}
