{
	"name": "@blokjs/trigger-http",
	"version": "0.1.1",
	"description": "Trigger for HTTP requests",
	"type": "module",
	"engines": {
		"node": ">=18.0.0"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"author": "Deskree Technologies Inc.",
	"license": "Apache-2.0",
	"scripts": {
		"dev": "bun --watch run src/index.ts",
		"start": "bun run dist/index.js",
		"reload": "bun --env-file=.env.local run src/index.ts",
		"build": "rimraf ./dist && tsc && copyfiles -u 1 src/nodes/**/*.html src/nodes/**/*.md dist/",
		"infra:dev": "rimraf ./dist && tsc && copyfiles -u 1 src/nodes/**/*.html src/nodes/**/*.md dist/ && docker compose --file ./infra/docker-compose.yml up --build --watch",
		"infra:build": "tsc --watch -p tsconfig.json --diagnostics",
		"test": "vitest run",
		"test:dev": "vitest"
	},
	"devDependencies": {
		"@types/ejs": "^3.1.5",
		"@types/node": "^22.15.21",
		"@types/pg": "^8.16.0",
		"copyfiles": "^2.4.1",
		"rimraf": "^6.1.2",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@ai-sdk/openai": "^1.3.22",
		"@blokjs/api-call": "^0.6.21",
		"@blokjs/helper": "^0.6.21",
		"@blokjs/helpers": "^0.6.21",
		"@blokjs/if-else": "^0.6.21",
		"@blokjs/runner": "^0.6.21",
		"@blokjs/shared": "^0.6.21",
		"@blokjs/trigger-mcp": "^0.6.21",
		"@blokjs/trigger-sse": "^0.6.21",
		"@blokjs/trigger-webhook": "^0.6.21",
		"@blokjs/trigger-websocket": "^0.6.21",
		"@hono/node-server": "^1.19.9",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/exporter-prometheus": "^0.57.2",
		"@opentelemetry/resources": "^1.30.1",
		"@opentelemetry/sdk-metrics": "^1.30.1",
		"@opentelemetry/sdk-trace-base": "^1.30.1",
		"@opentelemetry/sdk-trace-web": "^1.30.1",
		"@opentelemetry/semantic-conventions": "^1.39.0",
		"ai": "^4.3.16",
		"ejs": "^3.1.10",
		"hono": "^4.11.7",
		"mongodb": "^7.0.0",
		"pg": "^8.18.0",
		"uuid": "^11.1.0",
		"zod": "^3.24.2"
	},
	"private": true
}
