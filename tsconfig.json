{
	"compilerOptions": {
		"target": "es2022",
		"module": "es2022",
		"moduleResolution": "bundler",
		"rootDir": "./",
		"declaration": true,
		"sourceMap": true,
		"outDir": "./dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noUnusedLocals": true,
		"noImplicitReturns": true,
		"skipLibCheck": true
	},
	"compileOnSave": true,
	"typedocOptions": {
		"includeVersion": true,
		"readme": "none",
		"entryPoints": ["./core/runner/src/index.ts", "./core/shared/src/index.ts"],
		"plugin": ["typedoc-plugin-markdown"],
		"out": "./docs/ref"
	},
	"include": ["./core/**/*"],
	"exclude": ["node_modules", "README.md", "LICENSE"]
}
