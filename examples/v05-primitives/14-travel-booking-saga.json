{
	"name": "Travel Booking Saga",
	"version": "1.0.0",
	"description": "Books a flight + hotel + car as a saga. If any step fails, the previously successful steps are compensated in reverse order — cancel car if hotel failed, cancel hotel if car failed, etc. The catch arm reads ctx.state to know which steps succeeded and conditionally undoes them. Demonstrates: tryCatch with manual compensation chain in catch, branch guards on each compensation so we don't try to cancel things that never got booked, $.error proxy to surface which step failed in the response. This is the classic saga pattern done declaratively rather than with imperative code.",
	"trigger": {
		"http": {
			"method": "POST",
			"path": "/travel/book",
			"middleware": ["auth-check"]
		}
	},
	"steps": [
		{
			"id": "saga",
			"tryCatch": {
				"try": [
					{
						"id": "book-flight",
						"use": "flight-api",
						"type": "module",
						"idempotencyKey": "flight-$.req.body.bookingId",
						"inputs": {
							"action": "book",
							"from": "$.req.body.from",
							"to": "$.req.body.to",
							"date": "$.req.body.date",
							"passenger": "$.state.identity.sub"
						}
					},
					{
						"id": "book-hotel",
						"use": "hotel-api",
						"type": "module",
						"idempotencyKey": "hotel-$.req.body.bookingId",
						"inputs": {
							"action": "book",
							"city": "$.req.body.to",
							"checkIn": "$.req.body.date",
							"nights": "$.req.body.nights",
							"guest": "$.state.identity.sub"
						}
					},
					{
						"id": "book-car",
						"use": "car-api",
						"type": "module",
						"idempotencyKey": "car-$.req.body.bookingId",
						"inputs": {
							"action": "book",
							"city": "$.req.body.to",
							"pickup": "$.req.body.date",
							"return": "$.req.body.date + $.req.body.nights days",
							"driver": "$.state.identity.sub"
						}
					},
					{
						"id": "respond-ok",
						"use": "@blokjs/respond",
						"type": "module",
						"inputs": {
							"status": 201,
							"body": {
								"bookingId": "$.req.body.bookingId",
								"flight": "$.state['book-flight'].id",
								"hotel": "$.state['book-hotel'].id",
								"car": "$.state['book-car'].id"
							}
						}
					}
				],
				"catch": [
					{
						"id": "compensate-car",
						"branch": {
							"when": "$.state['book-car'] !== undefined",
							"then": [
								{
									"id": "cancel-car",
									"use": "car-api",
									"type": "module",
									"inputs": {
										"action": "cancel",
										"id": "$.state['book-car'].id",
										"reason": "saga-rollback"
									}
								}
							]
						}
					},
					{
						"id": "compensate-hotel",
						"branch": {
							"when": "$.state['book-hotel'] !== undefined",
							"then": [
								{
									"id": "cancel-hotel",
									"use": "hotel-api",
									"type": "module",
									"inputs": {
										"action": "cancel",
										"id": "$.state['book-hotel'].id",
										"reason": "saga-rollback"
									}
								}
							]
						}
					},
					{
						"id": "compensate-flight",
						"branch": {
							"when": "$.state['book-flight'] !== undefined",
							"then": [
								{
									"id": "cancel-flight",
									"use": "flight-api",
									"type": "module",
									"inputs": {
										"action": "cancel",
										"id": "$.state['book-flight'].id",
										"reason": "saga-rollback"
									}
								}
							]
						}
					},
					{
						"id": "respond-failed",
						"use": "@blokjs/respond",
						"type": "module",
						"inputs": {
							"status": 502,
							"body": {
								"error": "Booking saga rolled back",
								"failedAt": "$.error.name",
								"reason": "$.error.message",
								"bookingId": "$.req.body.bookingId"
							}
						}
					}
				]
			}
		}
	]
}
